# ── 대법원 파싱봇 환경설정 (.env) ──
# 실제 값은 .env 파일에 넣으세요. (.env 는 커밋 금지)

# 나의사건검색 진입 URL (현행 ssgo 시스템)
# ※ LawTop 이 쓰던 레거시 safind.scourt.go.kr 는 폐지(DNS 해석 불가)되어,
#   현재는 ssgo.scourt.go.kr 로 운영됩니다. 구조가 바뀌면 src/selectors.ts 조정.
SCOURT_FORM_URL=https://ssgo.scourt.go.kr/ssgo/index.on?cortId=www

# 브라우저 표시 여부 (디버깅 시 false 권장: 캡차 흐름을 눈으로 확인)
HEADLESS=true

# 병렬 워커 수 (LawTop WV1~3 대응). 과도한 동시 요청은 차단 위험.
BOT_CONCURRENCY=2

# 캡차 OCR 재시도 횟수 (OCR 실패 시 새 캡차 받아 재시도)
CAPTCHA_MAX_RETRY=5

# 요청 간 최소 대기(ms) - 차단 회피용 (사람 비슷한 간격)
REQUEST_DELAY_MS=1500

# ── 워커 HTTP 서버 (LawyGo 웹앱이 호출) ──
# 봇을 'npm run serve' 로 띄우면 이 포트에서 /search 를 받습니다.
BOT_PORT=8787
# 웹앱↔워커 공유 시크릿. 반드시 임의의 긴 문자열로 설정하세요(미설정 시 인증 없음=위험).
BOT_API_TOKEN=

# ── OCR 프로바이더 선택: ddddocr | tesseract | clova | vision ──
# 권장: ddddocr (캡차 특화 무료 오픈소스, 별도 HTTP 사이드카 필요)
OCR_PROVIDER=ddddocr

# ddddocr 사이드카 주소 (OCR_PROVIDER=ddddocr 일 때)
# 실행: docker run -d -p 8000:8000 sml2h3/ddddocr-fastapi
#   또는  pip install ddddocr && python -m ddddocr api --port 8000
DDDDOCR_URL=http://127.0.0.1:8000
# 결과 문자 범위 제한(선택). 숫자 캡차면 0123456789 처럼 지정해 정확도 향상.
DDDDOCR_CHARSETS=

# Naver CLOVA OCR (OCR_PROVIDER=clova 일 때) — 유료, 정확도 최상
CLOVA_OCR_URL=
CLOVA_OCR_SECRET=

# Google Cloud Vision (OCR_PROVIDER=vision 일 때)
GOOGLE_VISION_API_KEY=

# ── Supabase (작업 큐 + 결과 저장) ──
# npm run queue (권장): Vercel ↔ Supabase ↔ 로컬 봇 연동에 service_role 필수
# Dashboard → Settings → API → service_role (Vercel SUPABASE_SERVICE_ROLE_KEY 와 동일)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 큐 폴링 간격(ms). 기본 3000
# QUEUE_POLL_MS=3000

# Railway CLI 배포 (deploy-railway.ps1) — 둘 중 하나만 설정 (동시 설정 금지)
# Account token (권장): https://railway.com/account/tokens → No workspace → RAILWAY_API_TOKEN=
# Project token:        프로젝트 Settings → Tokens → RAILWAY_TOKEN=
RAILWAY_API_TOKEN=
# RAILWAY_TOKEN=
