{
  "name": "lawygo-parsing-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "대법원 나의사건검색 파싱봇 - LawTop GL(LawTopParsingBotWV) 방식 재구현 (Playwright + OCR + cheerio)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "postinstall": "playwright install chromium",
    "search": "tsx src/index.ts",
    "batch": "tsx src/index.ts --file",
    "serve": "tsx src/server.ts",
    "queue": "tsx src/queueWorker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "iconv-lite": "^0.6.3",
    "playwright": "^1.49.0",
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
}
